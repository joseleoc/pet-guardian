{
  "name": "@pet-guardian/supabase",
  "version": "0.1.0",
  "main": "database.types.ts",
  "types": "database.types.ts",
  "private": false,
  "description": "Shared Supabase types and config for Pet Guardian projects.",
  "scripts": {
    "link": "npx supabase link --project-ref \"$PROJECT_REF\"",
    "gen": "npx supabase gen types typescript --project-id \"$PROJECT_REF\" --schema public > supabase/database.types.ts",
    "migrate": "npx supabase db push"
  },
  "keywords": [
    "supabase",
    "types",
    "shared"
  ],
  "author": "Pet Guardian Team",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./database.types.ts",
      "default": "./database.types.ts"
    },
    "./database.types": {
      "types": "./database.types.ts",
      "default": "./database.types.ts"
    }
  },
  "dependencies": {
    "supabase": "^2.83.0"
  }
}